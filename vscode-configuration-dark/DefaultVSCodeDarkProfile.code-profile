{"name":"DefaultVSCodeDarkProfile","settings":"{\"settings\":\"{\\n  // UI theme for the entire VS Code workbench.\\n  \\\"workbench.colorTheme\\\": \\\"Bluloco Dark Muted W77\\\",\\n  // Editor text size.\\n  \\\"editor.fontSize\\\": 15,\\n  // Wrap editor lines at a bounded width instead of the full editor width.\\n  \\\"editor.wordWrap\\\": \\\"bounded\\\",\\n  // Maximum column used when word wrap is bounded.\\n  \\\"editor.wordWrapColumn\\\": 120,\\n  // Editor font stack, with fallbacks if the first font is unavailable.\\n  \\\"editor.fontFamily\\\": \\\"'AudioLink Mono', 'Anka/Coder', 'Anka/Coder Condensed', 'Courier New', monospace\\\",\\n  // Editor font weight.\\n  \\\"editor.fontWeight\\\": \\\"400\\\",\\n  // Enable programming ligatures in the editor font, if supported.\\n  \\\"editor.fontLigatures\\\": true,\\n  // Editor line height multiplier.\\n  \\\"editor.lineHeight\\\": 1.3,\\n  // Extra spacing between editor characters.\\n  \\\"editor.letterSpacing\\\": 0.5,\\n  // Python type-checking strictness used by the Python language server.\\n  \\\"python.analysis.typeCheckingMode\\\": \\\"standard\\\",\\n  // Terminal font stack; separate from the editor font stack.\\n  \\\"terminal.integrated.fontFamily\\\": \\\"'AudioLink Mono', 'Anka/Coder', 'Anka/Coder Condensed', 'Courier New', monospace\\\",\\n  // Terminal font size.\\n  \\\"terminal.integrated.fontSize\\\": 14,\\n  // Terminal font weight.\\n  \\\"terminal.integrated.fontWeight\\\": \\\"200\\\",\\n  // Terminal line height multiplier.\\n  \\\"terminal.integrated.lineHeight\\\": 1.25,\\n  // Extra spacing between terminal characters.\\n  \\\"terminal.integrated.letterSpacing\\\": 2,\\n  // Custom UI font family used by the Custom UI Style extension.\\n  // Dependency: requires the extension to be installed and enabled.\\n  \\\"custom-ui-style.font.sansSerif\\\": \\\"Charlie Display\\\",\\n  // Default profile used when opening a new window.\\n  \\\"window.newWindowProfile\\\": \\\"Default\\\",\\n  // Python file formatting behavior.\\n  // Dependency: ms-python.black-formatter must be installed for the formatter ID to work.\\n  \\\"[python]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"ms-python.black-formatter\\\",\\n    // Disable auto-format on save for Python.\\n    \\\"editor.formatOnSave\\\": false,\\n    // Run organize imports only when explicitly requested.\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.organizeImports\\\": \\\"explicit\\\"\\n    }\\n  },\\n  // Arguments passed to black formatter.\\n  // Dependency: used by the Black formatter extension.\\n  \\\"black-formatter.args\\\": [\\n    \\\"--line-length\\\",\\n    \\\"120\\\"\\n  ],\\n  // Arguments passed to isort.\\n  // Dependency: used by the isort extension.\\n  \\\"isort.args\\\": [\\n    \\\"--profile\\\",\\n    \\\"black\\\"\\n  ],\\n  // JSONC files use built-in JSON language features for formatting.\\n  \\\"[jsonc]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\"\\n  },\\n  // JSON files use built-in JSON language features for formatting.\\n  \\\"[json]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\"\\n  },\\n  // Disable delete confirmation in Explorer.\\n  \\\"explorer.confirmDelete\\\": false,\\n  // Run Makefile configuration automatically when a Makefile is opened.\\n  \\\"makefile.configureOnOpen\\\": true,\\n  // JavaScript React files use the built-in TypeScript language service for formatting.\\n  \\\"[javascriptreact]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.typescript-language-features\\\"\\n  },\\n  // Font size for the debug console.\\n  \\\"debug.console.fontSize\\\": 13,\\n  // Disable drag-and-drop confirmation in Explorer.\\n  \\\"explorer.confirmDragAndDrop\\\": false,\\n  // CSS files use Prettier for formatting.\\n  // Dependency: esbenp.prettier-vscode must be installed.\\n  \\\"[css]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\"\\n  },\\n  // TypeScript files use the built-in TypeScript language service for formatting.\\n  \\\"[typescript]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.typescript-language-features\\\"\\n  },\\n  // TypeScript React files use the built-in TypeScript language service for formatting.\\n  \\\"[typescriptreact]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.typescript-language-features\\\"\\n  },\\n  // Prefer Claude Code to open in the panel area.\\n  // Dependency: works only if Claude Code extension is installed.\\n  \\\"claudeCode.preferredLocation\\\": \\\"panel\\\",\\n  // Disable editor minimap.\\n  \\\"editor.minimap.enabled\\\": false,\\n  // Custom dictionary words for the spell checker.\\n  // Dependency: requires the cSpell extension.\\n  \\\"cSpell.userWords\\\": [\\n    \\\"actix\\\",\\n    \\\"chrono\\\",\\n    \\\"dotenv\\\",\\n    \\\"dotenvy\\\",\\n    \\\"dtos\\\",\\n    \\\"jsonwebtoken\\\",\\n    \\\"passw\\\",\\n    \\\"reqwest\\\",\\n    \\\"splitn\\\",\\n    \\\"sqlx\\\",\\n    \\\"subsecond\\\",\\n    \\\"timestamptz\\\",\\n    \\\"urlencoding\\\",\\n    \\\"ziminpro\\\"\\n  ],\\n  // Width of tree indentation in the Explorer and similar tree views.\\n  \\\"workbench.tree.indent\\\": 24,\\n  // Always show tree indent guides.\\n  \\\"workbench.tree.renderIndentGuides\\\": \\\"always\\\",\\n  // Workbench color overrides.\\n  // Dependency: custom colors only apply where VS Code supports these token names.\\n  \\\"workbench.colorCustomizations\\\": {\\n    // Color for tree indent guide lines.\\n    \\\"tree.indentGuidesStroke\\\": \\\"#2a534e\\\",\\n    // Debug console info message color.\\n    \\\"debugConsole.infoForeground\\\": \\\"#96b0f9\\\",\\n    // Debug console warning message color.\\n    \\\"debugConsole.warningForeground\\\": \\\"#ffcc00\\\",\\n    // Debug console error message color.\\n    \\\"debugConsole.errorForeground\\\": \\\"#cccccc\\\",\\n    // Debug console source file path color.\\n    \\\"debugConsole.sourceForeground\\\": \\\"#cccccc\\\"\\n  },\\n  // Rust file settings.\\n  \\\"[rust]\\\": {\\n    // Use rust-analyzer for formatting Rust files.\\n    // Dependency: rust-lang.rust-analyzer must be installed.\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.defaultFormatter\\\": \\\"rust-lang.rust-analyzer\\\",\\n    // Run fix and organize imports only when explicitly requested.\\n    \\\"editor.codeActionsOnSave\\\": {\\n      \\\"source.fixAll\\\": \\\"explicit\\\",\\n      \\\"source.organizeImports\\\": \\\"explicit\\\"\\n    }\\n  },\\n  // Suppress LLDB update notifications.\\n  // Dependency: applies if the LLDB extension is installed.\\n  \\\"lldb.suppressUpdateNotifications\\\": true,\\n  // Haskell HLS management handled by GHCup.\\n  // Dependency: relevant to Haskell tooling setup.\\n  \\\"haskell.manageHLS\\\": \\\"GHCup\\\",\\n  // Enable Rust analyzer test explorer integration.\\n  \\\"rust-analyzer.testExplorer\\\": true,\\n  // Cursor blinking style.\\n  \\\"editor.cursorBlinking\\\": \\\"expand\\\",\\n  // SQL files use the Prettier SQL formatter.\\n  // Dependency: cweijan.vscode-postgresql-client2 must be installed.\\n  \\\"[sql]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"cweijan.vscode-postgresql-client2\\\"\\n  },\\n  // Automatically update Go tools.\\n  \\\"go.toolsManagement.autoUpdate\\\": true,\\n  // Automatically fetch Git changes.\\n  \\\"git.autofetch\\\": true,\\n  // Disable confirmation when syncing Git.\\n  \\\"git.confirmSync\\\": false,\\n  // Custom CSS overrides for UI font sizes.\\n  // Dependency: requires the Custom UI Style extension.\\n  // Variables section and Outline section; Requires \\\"Custom UI Style\\\" extension to apply these styles.\\n  \\\"custom-ui-style.stylesheet\\\": {\\n    // Change font size for most workbench UI content.\\n    \\\".monaco-workbench .part > .content\\\": \\\"font-size: 15px !important;\\\",\\n    // Debug Variables/Watch section on macOS.\\n    \\\".monaco-workbench.mac .debug-pane .monaco-list-row .expression\\\": \\\"font-size: 13px !important;\\\",\\n    // Debug hover widget content on macOS.\\n    \\\".monaco-workbench.mac .debug-hover-widget .monaco-list-row .expression\\\": \\\"font-size: 13px !important;\\\"\\n  },\\n  \\\"chat.mcp.serverSampling\\\": {\\n    \\\"Global in Code: io.github.miroapp/mcp-server\\\": {\\n      \\\"allowedModels\\\": [\\n        \\\"copilot/auto\\\",\\n        \\\"copilotcli/claude-haiku-4.5\\\",\\n        \\\"copilot/claude-haiku-4.5\\\"\\n      ]\\n    }\\n  },\\n  \\\"chat.viewSessions.orientation\\\": \\\"stacked\\\",\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+[\\\",\\n        \\\"command\\\": \\\"workbench.action.chat.previousCodeBlock\\\",\\n        \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+pageup\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.previousCodeBlock\\\",\\n        \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+[\\\",\\n        \\\"command\\\": \\\"editor.action.accessibleViewPreviousCodeBlock\\\",\\n        \\\"when\\\": \\\"accessibleViewContainsCodeBlocks && accessibleViewCurrentProviderId == 'inlineChat' || accessibleViewContainsCodeBlocks && accessibleViewCurrentProviderId == 'panelChat' || accessibleViewContainsCodeBlocks && accessibleViewCurrentProviderId == 'quickChat'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+pageup\\\",\\n        \\\"command\\\": \\\"-editor.action.accessibleViewPreviousCodeBlock\\\",\\n        \\\"when\\\": \\\"accessibleViewContainsCodeBlocks && accessibleViewCurrentProviderId == 'inlineChat' || accessibleViewContainsCodeBlocks && accessibleViewCurrentProviderId == 'panelChat' || accessibleViewContainsCodeBlocks && accessibleViewCurrentProviderId == 'quickChat'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+l\\\",\\n        \\\"command\\\": \\\"-toggleSearchEditorContextLines\\\",\\n        \\\"when\\\": \\\"inSearchEditor\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+l\\\",\\n        \\\"command\\\": \\\"-toggleFindInSelection\\\",\\n        \\\"when\\\": \\\"editorFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+alt+o\\\",\\n        \\\"command\\\": \\\"editor.action.organizeImports\\\",\\n        \\\"when\\\": \\\"textInputFocus && !editorReadonly && supportedCodeAction =~ /(\\\\\\\\s|^)source\\\\\\\\.organizeImports\\\\\\\\b/\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+alt+o\\\",\\n        \\\"command\\\": \\\"-editor.action.organizeImports\\\",\\n        \\\"when\\\": \\\"textInputFocus && !editorReadonly && supportedCodeAction =~ /(\\\\\\\\s|^)source\\\\\\\\.organizeImports\\\\\\\\b/\\\"\\n    }\\n]\",\"platform\":1}","extensions":"[{\"identifier\":{\"id\":\"aleksandra.go-group-imports\",\"uuid\":\"a34ccfaa-61bb-4697-9e55-e9b1f077cfa9\"},\"displayName\":\"Go Group Imports\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"anthropic.claude-code\",\"uuid\":\"3c13ae49-babe-45fe-8c48-5e45077a62bf\"},\"displayName\":\"Claude Code for VS Code\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"azemoh.one-monokai\",\"uuid\":\"b027c4b2-25ad-46db-b574-05dae3b2dc92\"},\"displayName\":\"One Monokai Theme\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"burkeholland.simple-react-snippets\",\"uuid\":\"a84825e8-5f04-4988-b85a-4942e795bcbe\"},\"displayName\":\"Simple React Snippets\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"cweijan.dbclient-jdbc\",\"uuid\":\"1fe0d785-8db6-44ef-8113-cb0d98a88473\"},\"displayName\":\"Database Client JDBC\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"cweijan.vscode-postgresql-client2\",\"uuid\":\"79ec8a75-6869-4959-9477-348da39430be\"},\"displayName\":\"PostgreSQL\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"dsznajder.es7-react-js-snip